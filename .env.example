# ── Application ──
APP_NAME=HDFC_RAG_Assistant
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hdfc_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# MongoDB
MONGODB_URL=mongodb://localhost:27017/hdfc_rag
DATABASE_TYPE=mongodb  # options: postgres, mongodb
DATABASE_URL=postgresql+asyncpg://postgres:postgres123@localhost:5432/hdfc_rag
DATABASE_URL_SYNC=postgresql://postgres:postgres123@localhost:5432/hdfc_rag

# ── ChromaDB ──
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=hdfc_mitc_docs

# ── Embeddings ──
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── LLM ──
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ── RAG Configuration ──
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.3

# ── Document Ingestion ──
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=50

# LLM_PROVIDER=ollama
# LLM_MODEL=qwen3.5:9b
# OLLAMA_BASE_URL=http://localhost:11434
