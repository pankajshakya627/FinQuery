# ── Application ──
APP_NAME=HDFC_RAG_Assistant
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hdfc_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# MongoDB
MONGODB_URL=mongodb://localhost:27017/hdfc_rag
DATABASE_TYPE=mongodb  # options: postgres, mongodb
DATABASE_URL=postgresql+asyncpg://postgres:postgres123@localhost:5432/hdfc_rag
DATABASE_URL_SYNC=postgresql://postgres:postgres123@localhost:5432/hdfc_rag

# ── ChromaDB ──
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=hdfc_mitc_docs

# ── Embeddings ──
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── LLM ──
LLM_PROVIDER=openai  # options: openai, ollama, azure
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ── Ollama ──
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen3.5:9b
# OLLAMA_BASE_URL=http://localhost:11434

# ── Azure OpenAI ──
# LLM_PROVIDER=azure
# AZURE_OPENAI_API_KEY=your-azure-api-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# AZURE_OPENAI_AD_DEPLOYMENT_NAME=your_deployment_name
# AZURE_OPENAI_API_VERSION=2023-05-15
